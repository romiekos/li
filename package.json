{
  "name": "li",
  "version": "0.1.0",
  "description": "A fast universal AI text rewriting layer for desktop.",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "pnpm build && electron-builder --publish never",
    "dist:mac": "pnpm build && electron-builder --mac --publish never",
    "dist:win": "pnpm build && electron-builder --win --publish never",
    "release": "pnpm build && electron-builder --publish always"
  },
  "build": {
    "appId": "com.li.rewriter",
    "productName": "Li",
    "icon": "build/icon.icns",
    "files": [
      "out/**"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "romiekos",
      "repo": "li"
    },
    "afterSign": "scripts/notarize.mjs",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Li uses System Events to copy your selected text and paste the rewritten result back.",
        "NSAccessibilityUsageDescription": "Li needs Accessibility access to listen for the global hotkeys you configure.",
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "Li",
      "icon": "build/icon.icns",
      "window": {
        "width": 540,
        "height": 360
      },
      "contents": [
        {
          "x": 150,
          "y": 160,
          "type": "file"
        },
        {
          "x": 390,
          "y": 160,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^5.4.21"
  }
}
